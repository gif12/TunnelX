<UserControl x:Class="AppTunnel.Views.Controls.AppNotificationCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="NotificationRoot"
             MinWidth="300"
             MaxWidth="380"
             RenderTransformOrigin="0.5,0.5">
    <UserControl.RenderTransform>
        <TranslateTransform x:Name="SlideTransform" X="0" Y="0"/>
    </UserControl.RenderTransform>
    <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
        <!-- Shadow on a duplicate shell so inner content (icon) is not rasterized through DropShadowEffect -->
        <Border CornerRadius="10"
                Margin="0,2,6,4"
                Background="{StaticResource CardBrush}"
                IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="18" Opacity="0.55" ShadowDepth="3"/>
            </Border.Effect>
        </Border>
        <Border x:Name="RootBorder"
                CornerRadius="10"
                BorderThickness="1"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                Padding="0">
        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="AccentBar"
                    Grid.Column="0"
                    CornerRadius="10,0,0,10"
                    Background="{StaticResource AccentBrush}"/>

            <Grid Grid.Column="1" Margin="12,10,14,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Circular Tx badge (Telegram-style avatar; single shape, no square-in-ring). -->
                <Grid Width="42" Height="42"
                      Grid.Column="0"
                      VerticalAlignment="Top"
                      SnapsToDevicePixels="True"
                      UseLayoutRounding="True"
                      FlowDirection="LeftToRight">
                    <Ellipse Fill="{StaticResource PrimaryBrush}">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#C2410C"
                                              BlurRadius="8"
                                              Opacity="0.22"
                                              ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Text="Tx"
                               FontSize="17"
                               FontWeight="Bold"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,-1,0,0"
                               TextOptions.TextFormattingMode="Display"
                               TextOptions.TextRenderingMode="ClearType"/>
                </Grid>

                <!-- ZIndex: StackPanel fills the cell; close must sit above it for hover / hit-test -->
                <StackPanel Grid.Column="1"
                            Panel.ZIndex="0"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="AppNameText"
                               Text="TunnelX"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,2"/>
                    <TextBlock x:Name="TitleText"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,2"/>
                    <TextBlock x:Name="MessageText"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               MaxHeight="120"
                               TextTrimming="CharacterEllipsis"/>

                    <Button x:Name="ActionButton"
                            Visibility="Collapsed"
                            Margin="0,10,0,0"
                            Padding="14,6"
                            HorizontalAlignment="Stretch"
                            Click="OnActionClick"/>
                </StackPanel>

                <Button x:Name="CloseButton"
                        Grid.Column="1"
                        Panel.ZIndex="100"
                        Content="✕"
                        Width="26"
                        Height="26"
                        Padding="0"
                        FontSize="11"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,-4,0,0"
                        Visibility="Collapsed"
                        Style="{StaticResource WindowControlButton}"
                        PreviewMouseLeftButtonUp="OnClosePreviewClick"
                        Click="OnCloseClick"/>
            </Grid>
        </Grid>
        </Border>
    </Grid>
</UserControl>

