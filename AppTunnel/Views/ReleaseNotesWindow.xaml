<Window x:Class="AppTunnel.Views.ReleaseNotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:AppTunnel.Services"
        Title="TunnelX"
        Width="520"
        Height="460"
        MinWidth="420"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FlowDirection="{Binding Source={x:Static services:LocalizationService.Instance}, Path=FlowDirection}"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip">
    <Border Background="{StaticResource BackgroundBrush}"
            CornerRadius="14"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Padding="0">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="24" Opacity="0.65" ShadowDepth="0"/>
        </Border.Effect>
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <TextBlock x:Name="TitleText"
                           Text="تغییرات نسخه"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,36,0"/>
                <Button Content="✕"
                        Width="28"
                        Height="28"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Style="{StaticResource WindowControlButton}"
                        Click="OnCloseClick"/>
            </Grid>

            <Border Grid.Row="1"
                    Background="#18FFFFFF"
                    CornerRadius="8"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="BodyPanel"/>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,14,0,0"
                        FlowDirection="{Binding Source={x:Static services:LocalizationService.Instance}, Path=FlowDirection}">
                <Button x:Name="DownloadButton"
                        Content="دانلود این نسخه"
                        Style="{StaticResource TelegramChannelButton}"
                        MinWidth="160"
                        Padding="18,9"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Margin="0,0,8,0"
                        Visibility="Collapsed"
                        Click="OnDownloadClick"/>
                <Button x:Name="CloseButton"
                        Content="بستن"
                        Style="{StaticResource SecondaryButton}"
                        MinWidth="100"
                        Padding="18,8"
                        Click="OnCloseClick"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
