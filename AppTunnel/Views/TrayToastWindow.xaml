<Window x:Class="AppTunnel.Views.TrayToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AppTunnel.Views.Controls"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowActivated="False"
        Focusable="False">
    <controls:AppNotificationCard x:Name="NotificationCard"
                                MouseLeftButtonUp="OnCardClick"/>
</Window>
